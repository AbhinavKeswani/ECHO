# ECHO credentials — copy to `.env` and fill in, then `echo` auto-loads it.
#   cp .env.example .env

# --- Spotify (required for sync + playlists) ---------------------------------
# 1. Go to https://developer.spotify.com/dashboard and create an app.
# 2. In the app's settings, add this exact Redirect URI:
#        http://127.0.0.1:8899/callback
# 3. Copy the Client ID and Client Secret below.
ECHO_SPOTIFY_CLIENT_ID=
ECHO_SPOTIFY_CLIENT_SECRET=

# Only change if you registered a different redirect URI on the Spotify app.
# ECHO_SPOTIFY_REDIRECT_URI=http://127.0.0.1:8899/callback

# --- Optional tuning ---------------------------------------------------------
# Seconds of each track to analyze (central window). 0 = whole track (~4x slower).
# ECHO_ANALYZE_SECONDS=120
# Keep downloaded audio after analysis (uses disk; lets you re-analyze without re-download).
# ECHO_KEEP_AUDIO=0
